{
  "name": "merakilab/meraki-data-safety",
  "description": "Data backup & restore safety layer for Laravel migrations",
  "version": "dev-main",
  "type": "library",
  "require": {
    "php": "^8.2",
    "illuminate/support": "^v12.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "orchestra/testbench": "^10.0"
  },
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "Meraki\\Packages\\DataSafety\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Meraki\\Packages\\DataSafety\\Tests\\": "tests/"
    }
  },
  "authors": [
    {
      "name": "DatPA",
      "email": "datpa@merakilabs.tech"
    }
  ],
  "minimum-stability": "stable",
  "scripts": {
    "test": "vendor/bin/phpunit"
  },
  "extra": {
    "laravel": {
      "providers": [
        "Meraki\\Packages\\DataSafety\\DataSafetyServiceProvider"
      ],
      "aliases": {
        "DataSafety": "Meraki\\Packages\\DataSafety\\Facades\\DataSafety"
      }
    }
  }
}
